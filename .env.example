NEXT_PUBLIC_SUPABASE_URL=https://dlfryjaqabwdrsymuzgj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key

# Server/local-worker only. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
CAREER_OS_LOCAL_USER_ID=replace-with-auth-user-uuid
CAREER_OS_SEED_USER_ID=replace-with-auth-user-uuid

# Local worker behavior.
CAREER_OS_WORKER_POLL_MS=10000
CAREER_OS_RUNTIME=codex-app-server
CODEX_APP_SERVER_COMMAND=codex
CODEX_APP_SERVER_ARGS=app-server,--listen,stdio://
